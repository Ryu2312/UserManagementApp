@page
@model UserManagementApp.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
            body {
                background: linear-gradient(rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.3)), url('/images/machu_picchu_bg.webp');
                background-size: cover;
                background-position: center;
                background-attachment: fixed;
                background-repeat: no-repeat;
                margin: 0;
                min-height: 100vh;
            }

            .top-bar {
                background-color: #b51217;
                height: 60px;
            }

            .login-container {
                min-height: calc(100vh - 110px);
            }

            .login-card {
                width: 100%;
                max-width: 360px;
                border-radius: 10px;
                padding: 25px;
                box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
            }

            .toggle-doc {
                display: flex;
                border: 1px solid #ced4da;
                border-radius: 6px;
                overflow: hidden;
                margin-bottom: 1rem;
            }

            .toggle-doc button {
                flex: 1;
                border: none;
                padding: 8px;
                background: #e9ecef;
                cursor: pointer;
                transition: 0.2s ease;
            }

            .toggle-doc button.active {
                background: #6c757d;
                color: white;
            }

            .login-btn {
                background-color: #0d5cab;
                color: white;
                border: none;
                cursor: pointer;
            }

            .login-btn:hover {
                background-color: #0b4f95;
            }

            .support {
                font-size: 0.85rem;
            }

            .footer-note {
                font-size: 0.8rem;
                color: #fff;
                text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
            }
    </style>
</head>

<body>
    <div class="top-bar d-flex justify-content-end align-items-center px-3">
        <span class="text-white fs-4">?</span>
    </div>

    <div class="container login-container d-flex justify-content-center align-items-center">
        <div class="login-card bg-white shadow">

            @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
            {
                <div class="alert alert-warning" role="alert">
                    @Model.StatusMessage
                </div>
            }

            <form method="post">
                <input asp-for="Input.DocumentType" type="hidden" id="documentTypeInput" />

                <div class="toggle-doc">
                    <button type="button" id="btnDni" class="active" onclick="setDocumentType('DNI')">
                        DNI
                    </button>
                    <button type="button" id="btnCe" onclick="setDocumentType('CE')">
                        CE
                    </button>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.DocumentNumber" class="form-label">Usuario</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input asp-for="Input.DocumentNumber" type="text" class="form-control" placeholder="Ingresar usuario" />
                    </div>
                    <span asp-validation-for="Input.DocumentNumber" class="text-danger"></span>
                </div>

                <div class="mb-2">
                    <label asp-for="Input.Password" class="form-label">Contraseña</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input asp-for="Input.Password" type="password" class="form-control" id="passwordInput" placeholder="Ingresar contraseña" />
                        <button type="button" class="input-group-text" onclick="togglePassword()">
                            <i class="bi bi-eye" id="eyeIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <a href="#" class="small text-decoration-none">¿Olvidó su contraseña?</a>
                </div>

                <div class="d-grid mb-3">
                    <button type="submit" class="btn login-btn">Ingresar</button>
                </div>

                <div class="d-grid mb-4">
                    <a asp-page="/Account/Activate" class="btn btn-outline-secondary">
                        Activar cuenta
                    </a>
                </div>
            </form>

            <div class="text-center support">
                <i class="bi bi-headset"></i>
                ¿Necesita ayuda?, <a href="#">contacte con el área de soporte</a>.
            </div>

        </div>
    </div>

    <div class="text-end p-3 footer-note">
        <small>PERÚ - Centro Nacional de Planeamiento Estratégico</small>
    </div>

    <partial name="_ValidationScriptsPartial" />

    <script>
            function setDocumentType(type) {
                document.getElementById("documentTypeInput").value = type;

                const btnDni = document.getElementById("btnDni");
                const btnCe = document.getElementById("btnCe");

                btnDni.classList.remove("active");
                btnCe.classList.remove("active");

                if (type === "DNI") {
                    btnDni.classList.add("active");
                } else {
                    btnCe.classList.add("active");
                }
            }

            function togglePassword() {
                const passwordInput = document.getElementById("passwordInput");
                const eyeIcon = document.getElementById("eyeIcon");

                if (passwordInput.type === "password") {
                    passwordInput.type = "text";
                    eyeIcon.classList.remove("bi-eye");
                    eyeIcon.classList.add("bi-eye-slash");
                } else {
                    passwordInput.type = "password";
                    eyeIcon.classList.remove("bi-eye-slash");
                    eyeIcon.classList.add("bi-eye");
                }
            }

            document.addEventListener("DOMContentLoaded", function () {
                const currentType = document.getElementById("documentTypeInput").value || "DNI";
                setDocumentType(currentType);
            });
    </script>
</body>

</html>