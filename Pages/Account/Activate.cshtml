@page
@model UserManagementApp.Pages.Account.ActivateModel
@{
    ViewData["Title"] = "Activación de cuenta";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/site.css" rel="stylesheet" />
</head>

<body class="activate-page">
    <div class="top-bar d-flex justify-content-end align-items-center px-3">
        <span class="text-white fs-4 fw-bold">?</span>
    </div>

    <div class="activation-container">
        <div class="activation-inner">

            @if (Model.IsSuccess)
            {
                <div class="confirm-card">
                    <div class="confirm-icon">
                        <i class="bi bi-rocket-takeoff"></i>
                    </div>

                    <div class="confirm-title">
                        ¡Bienvenido(a), @(string.IsNullOrWhiteSpace(Model.ActivatedUserName) ? "usuario" : Model.ActivatedUserName)!
                    </div>

                    <div class="confirm-message">
                        Su cuenta en el aplicativo X está activada.
                    </div>

                    <div class="confirm-message">
                        Ya puede iniciar sesión.
                    </div>

                    <a asp-page="/Account/Login" class="btn confirm-btn">
                        Iniciar sesión
                    </a>
                </div>
            }
            else
            {
                <div class="auth-card">

                    <div class="brand-section">
                        <h1 class="auth-title">Activación de cuenta</h1>
                        <p class="auth-subtitle">Complete sus datos para habilitar el acceso</p>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            @Model.StatusMessage
                        </div>
                    }

                    <form method="post">
                        <input asp-for="Input.DocumentType" type="hidden" id="documentTypeInput" />

                        <div class="toggle-doc">
                            <button type="button" id="btnDni" class="active" onclick="setDocumentType('DNI')">
                                DNI
                            </button>
                            <button type="button" id="btnCe" onclick="setDocumentType('CE')">
                                CE
                            </button>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.DocumentNumber" class="form-label">Número de documento</label>
                            <input asp-for="Input.DocumentNumber" class="form-control" placeholder="Ingrese su número de documento" />
                            <span asp-validation-for="Input.DocumentNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label">Correo</label>
                            <input asp-for="Input.Email" class="form-control" placeholder="Ingrese su correo" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.PhoneNumber" class="form-label">Celular</label>
                            <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Ingrese su celular" />
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label">Contraseña</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                <input asp-for="Input.Password" type="password" id="passwordInput" class="form-control"
                                       placeholder="Cree una contraseña" />
                                <button type="button" class="input-group-text" onclick="togglePassword('passwordInput', 'eyeIcon1')">
                                    <i class="bi bi-eye" id="eyeIcon1"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Input.ConfirmPassword" class="form-label">Confirmar contraseña</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                <input asp-for="Input.ConfirmPassword" type="password" id="confirmPasswordInput" class="form-control"
                                       placeholder="Confirme su contraseña" />
                                <button type="button" class="input-group-text" onclick="togglePassword('confirmPasswordInput', 'eyeIcon2')">
                                    <i class="bi bi-eye" id="eyeIcon2"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn primary-btn">Activar cuenta</button>
                        </div>

                        <div class="d-grid">
                            <a asp-page="/Account/Login" class="btn btn-outline-secondary">
                                Volver al login
                            </a>
                        </div>
                    </form>

                    <div class="help-section mt-4">
                        <i class="bi bi-headset"></i>
                        ¿Necesita ayuda?, <a href="#">contacte con el área de soporte</a>.
                    </div>
                </div>
            }

        </div>
    </div>

    <div class="bottom-bar">
        <div class="footer-note">PERÚ - Centro Nacional de Planeamiento Estratégico</div>
    </div>

    <partial name="_ValidationScriptsPartial" />

    <script>
            function setDocumentType(type) {
                document.getElementById("documentTypeInput").value = type;

                const btnDni = document.getElementById("btnDni");
                const btnCe = document.getElementById("btnCe");

                btnDni.classList.remove("active");
                btnCe.classList.remove("active");

                if (type === "DNI") {
                    btnDni.classList.add("active");
                } else {
                    btnCe.classList.add("active");
                }
            }

            function togglePassword(inputId, iconId) {
                const passwordInput = document.getElementById(inputId);
                const eyeIcon = document.getElementById(iconId);

                if (passwordInput.type === "password") {
                    passwordInput.type = "text";
                    eyeIcon.classList.remove("bi-eye");
                    eyeIcon.classList.add("bi-eye-slash");
                } else {
                    passwordInput.type = "password";
                    eyeIcon.classList.remove("bi-eye-slash");
                    eyeIcon.classList.add("bi-eye");
                }
            }

            document.addEventListener("DOMContentLoaded", function () {
                const currentType = document.getElementById("documentTypeInput")?.value || "DNI";
                if (document.getElementById("documentTypeInput")) {
                    setDocumentType(currentType);
                }
            });
    </script>
</body>

</html>