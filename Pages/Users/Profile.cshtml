@page
@model UserManagementApp.Pages.Users.ProfileModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@{
    ViewData["Title"] = "Perfil de usuario";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
                                    body {
                                        margin: 0;
                                        background: #f3f3f3;
                                        font-family: "Segoe UI", Arial, sans-serif;
                                    }

                                    .top-bar {
                                        background-color: #b51217;
                                        height: 60px;
                                    }

                                    .profile-page {
                                        min-height: calc(100vh - 100px);
                                        background: linear-gradient(to bottom, #f5f5f5, #ececec);
                                        padding: 28px 18px;
                                    }

                                    .profile-shell {
                                        max-width: 1100px;
                                        margin: 0 auto;
                                    }

                                    .profile-header {
                                        background: white;
                                        border-radius: 10px;
                                        padding: 18px 22px;
                                        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
                                        display: flex;
                                        justify-content: space-between;
                                        align-items: center;
                                        gap: 16px;
                                        margin-bottom: 20px;
                                    }

                                    .profile-title {
                                        margin: 0;
                                        font-size: 26px;
                                        font-weight: 700;
                                        color: #2f2f2f;
                                    }

                                    .profile-subtitle {
                                        margin: 4px 0 0;
                                        color: #6f6f6f;
                                        font-size: 14px;
                                    }

                                    .profile-card {
                                        background: white;
                                        border-radius: 12px;
                                        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
                                        overflow: hidden;
                                    }

                                    .profile-card-top {
                                        padding: 24px;
                                        border-bottom: 1px solid #ececec;
                                        display: flex;
                                        gap: 18px;
                                        align-items: center;
                                        flex-wrap: wrap;
                                    }

                                    .avatar-box {
                                        width: 84px;
                                        height: 84px;
                                        border-radius: 50%;
                                        background: #6c757d;
                                        color: white;
                                        display: flex;
                                        align-items: center;
                                        justify-content: center;
                                        font-size: 34px;
                                        flex-shrink: 0;
                                    }

                                    .user-name {
                                        font-size: 24px;
                                        font-weight: 700;
                                        color: #2f2f2f;
                                        margin-bottom: 4px;
                                    }

                                    .user-meta {
                                        color: #6b6b6b;
                                        font-size: 14px;
                                        margin-bottom: 8px;
                                    }

                                    .badge-active {
                                        background: #198754;
                                        color: white;
                                        border-radius: 999px;
                                        padding: 6px 12px;
                                        font-size: 12px;
                                        font-weight: 600;
                                        display: inline-block;
                                    }

                                    .profile-card-body {
                                        padding: 24px;
                                    }

                                    .section-title {
                                        font-size: 18px;
                                        font-weight: 700;
                                        color: #3b3b3b;
                                        margin-bottom: 18px;
                                    }

                                    .info-grid {
                                        display: grid;
                                        grid-template-columns: repeat(2, minmax(0, 1fr));
                                        gap: 18px 20px;
                                    }

                                    .info-item {
                                        border: 1px solid #ececec;
                                        border-radius: 10px;
                                        padding: 14px 16px;
                                        background: #fafafa;
                                    }

                                    .info-label {
                                        display: block;
                                        font-size: 12px;
                                        font-weight: 700;
                                        text-transform: uppercase;
                                        letter-spacing: .02em;
                                        color: #7a7a7a;
                                        margin-bottom: 8px;
                                    }

                                    .info-value {
                                        font-size: 15px;
                                        color: #2f2f2f;
                                        word-break: break-word;
                                    }

                                    .bottom-bar {
                                        height: 40px;
                                        background: #f7f7f7;
                                        display: flex;
                                        align-items: center;
                                        justify-content: flex-end;
                                        padding: 0 22px;
                                        border-top: 1px solid #e5e5e5;
                                    }

                                    .footer-note {
                                        font-size: 11px;
                                        color: #666;
                                    }

                                    .modal-content {
                                        border-radius: 14px;
                                    }

                                    .session-warning-icon {
                                        font-size: 28px;
                                        color: #d39b00;
                                        line-height: 1;
                                    }

                                    .btn-warning {
                                        background-color: #d39b00;
                                        border-color: #d39b00;
                                        color: #1f1f1f;
                                        font-weight: 600;
                                    }

                                    .btn-warning:hover {
                                        background-color: #bf8d00;
                                        border-color: #bf8d00;
                                        color: #1f1f1f;
                                    }

                                    @@media (max-width: 768px) {
                                        .profile-header {
                                            flex-direction: column;
                                            align-items: stretch;
                                        }

                                        .info-grid {
                                            grid-template-columns: 1fr;
                                        }

                                        .profile-card-top {
                                            align-items: flex-start;
                                        }
                                    }
    </style>
</head>

<body>
    <div class="top-bar d-flex justify-content-end align-items-center px-3">
        <span class="text-white fs-4 fw-bold">?</span>
    </div>

    <div class="profile-page">
        <div class="profile-shell">

            <div class="profile-header">
                <div>
                    <h1 class="profile-title">Perfil de usuario</h1>
                    <p class="profile-subtitle">Información general del colaborador autenticado</p>
                </div>

                <form method="post" asp-page="/Account/Logout" class="m-0">
                    <button type="submit" class="btn btn-outline-secondary">
                        Cerrar sesión
                    </button>
                </form>
            </div>

            <div class="profile-card">
                @if (Model.Profile is null)
                {
                    <div class="p-4">
                        <div class="alert alert-warning mb-0">
                            No se encontró información del usuario.
                        </div>
                    </div>
                }
                else
                {
                    <div class="profile-card-top">
                        <div class="avatar-box">
                            <i class="bi bi-person-fill"></i>
                        </div>

                        <div>
                            <div class="user-name">@Model.Profile.FullName</div>
                            <div class="user-meta">
                                @Model.Profile.DocumentType - @Model.Profile.DocumentNumber
                            </div>
                            <span class="badge-active">Activo</span>
                        </div>
                    </div>

                    <div class="profile-card-body">
                        <div class="section-title">Datos personales y laborales</div>

                        <div class="info-grid">
                            <div class="info-item">
                                <span class="info-label">Nombres completos</span>
                                <div class="info-value">@Model.Profile.FullName</div>
                            </div>

                            <div class="info-item">
                                <span class="info-label">Tipo de documento</span>
                                <div class="info-value">@Model.Profile.DocumentType</div>
                            </div>

                            <div class="info-item">
                                <span class="info-label">Número de documento</span>
                                <div class="info-value">@Model.Profile.DocumentNumber</div>
                            </div>

                            <div class="info-item">
                                <span class="info-label">Fecha de nacimiento</span>
                                <div class="info-value">
                                    @(Model.Profile.BirthDate?.ToString("dd/MM/yyyy") ?? "-")
                                </div>
                            </div>

                            <div class="info-item">
                                <span class="info-label">Nacionalidad</span>
                                <div class="info-value">
                                    @(string.IsNullOrWhiteSpace(Model.Profile.Nationality) ? "-" : Model.Profile.Nationality)
                                </div>
                            </div>

                            <div class="info-item">
                                <span class="info-label">Sexo</span>
                                <div class="info-value">
                                    @(string.IsNullOrWhiteSpace(Model.Profile.Gender) ? "-" : Model.Profile.Gender)
                                </div>
                            </div>

                            <div class="info-item">
                                <span class="info-label">Correo principal</span>
                                <div class="info-value">@Model.Profile.Email</div>
                            </div>

                            <div class="info-item">
                                <span class="info-label">Correo secundario</span>
                                <div class="info-value">
                                    @(string.IsNullOrWhiteSpace(Model.Profile.SecondaryEmail)
                                        ? "-"
                                        : Model.Profile.SecondaryEmail)
                                </div>
                            </div>

                            <div class="info-item">
                                <span class="info-label">Teléfono móvil</span>
                                <div class="info-value">@Model.Profile.PhoneNumber</div>
                            </div>

                            <div class="info-item">
                                <span class="info-label">Teléfono secundario</span>
                                <div class="info-value">
                                    @(string.IsNullOrWhiteSpace(Model.Profile.SecondaryPhoneNumber)
                                        ? "-"
                                        : Model.Profile.SecondaryPhoneNumber)
                                </div>
                            </div>

                            <div class="info-item">
                                <span class="info-label">Tipo de contratación</span>
                                <div class="info-value">@Model.Profile.EmploymentType</div>
                            </div>

                            <div class="info-item">
                                <span class="info-label">Fecha de contratación</span>
                                <div class="info-value">@Model.Profile.HiringDate.ToString("dd/MM/yyyy")</div>
                            </div>

                            <div class="info-item">
                                <span class="info-label">Fecha de activación</span>
                                <div class="info-value">
                                    @(Model.Profile.ActivatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                                </div>
                            </div>

                            <div class="info-item">
                                <span class="info-label">Último acceso</span>
                                <div class="info-value">
                                    @(Model.Profile.LastLoginAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

        </div>
    </div>

    <div class="bottom-bar">
        <div class="footer-note">PERÚ - Centro Nacional de Planeamiento Estratégico</div>
    </div>

    <div class="modal fade" id="sessionWarningModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-body p-4">
                    <div class="d-flex gap-3 align-items-start">
                        <div class="session-warning-icon">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                        </div>

                        <div class="flex-grow-1">
                            <h5 class="mb-2 fw-bold">Su sesión está a punto de expirar</h5>
                            <p class="mb-3 text-muted">
                                Por seguridad, su sesión expirará en
                                <span id="countdownSeconds">10</span>
                                segundos. Para continuar, seleccione “Extender sesión”.
                            </p>

                            <div class="d-flex justify-content-end">
                                <button type="button" id="extendSessionBtn" class="btn btn-warning">
                                    Extender sesión
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const inactivityBeforeWarningMs = 20000;
        const warningCountdownSeconds = 10;
        const logoutUrl = '/Account/Logout';

        let inactivityTimer = null;
        let logoutTimer = null;
        let countdownInterval = null;
        let countdown = warningCountdownSeconds;
        let modalVisible = false;

        const modalElement = document.getElementById('sessionWarningModal');
        const countdownElement = document.getElementById('countdownSeconds');
        const extendSessionBtn = document.getElementById('extendSessionBtn');

        const warningModal = new bootstrap.Modal(modalElement, {
        backdrop: 'static',
        keyboard: false
        });

        function clearTimers() {
        if (inactivityTimer) clearTimeout(inactivityTimer);
        if (logoutTimer) clearTimeout(logoutTimer);
        if (countdownInterval) clearInterval(countdownInterval);
        }

        function resetInactivityFlow() {
        clearTimers();

        countdown = warningCountdownSeconds;
        countdownElement.textContent = countdown;

        inactivityTimer = setTimeout(showWarningModal, inactivityBeforeWarningMs);
        }

        function showWarningModal() {
        if (modalVisible) return;

        modalVisible = true;
        warningModal.show();

        logoutTimer = setTimeout(forceLogout, warningCountdownSeconds * 1000);

        countdownInterval = setInterval(() => {
        countdown--;
        countdownElement.textContent = countdown;

        if (countdown <= 0) {
        clearInterval(countdownInterval);
        }
        }, 1000);
        }

        function hideWarningModal() {
        modalVisible = false;
        warningModal.hide();
        }

        function forceLogout() {
        window.location.href = logoutUrl;
        }

        function extendSession() {
        hideWarningModal();
        resetInactivityFlow();
        }

        extendSessionBtn.addEventListener('click', extendSession);

        const activityEvents = ['click', 'keydown', 'mousemove', 'scroll'];

        activityEvents.forEach(eventName => {
        document.addEventListener(eventName, (event) => {
        if (modalVisible && modalElement.contains(event.target)) {
        return;
        }

        if (!modalVisible) {
        resetInactivityFlow();
        }
        }, { passive: true });
        });

        resetInactivityFlow();
    </script>
</body>

</html>